#!/usr/bin/env bash
# File: user-level/hooks/pre-commit
# Purpose: Block commits containing secrets, sensitive filenames, or personal data.
# Project: HumanSpark Engineering Standards | Date: 2026-04-01
#
# Overview: User-level pre-commit hook that scans staged files for three
# categories of sensitive content: dangerous filenames, secrets in diffs,
# and personal email addresses. Blocks on the first two, warns on the third
# (except in test fixtures). Deploy by setting git core.hooksPath or copying
# to .git/hooks/pre-commit per repo. Override with git commit --no-verify.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

errors=0
warnings=0

# --- 1. Sensitive filenames ---
sensitive_patterns=(
    'financial_summary'
    'purchase_ledger'
    'email-sweep'
    'pipeline\.md'
    'credentials'
    '\.env\.shared'
)

staged_files=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null)

if [[ -n "$staged_files" ]]; then
    for pattern in "${sensitive_patterns[@]}"; do
        matches=$(echo "$staged_files" | grep -iE "$pattern" || true)
        if [[ -n "$matches" ]]; then
            echo -e "${RED}BLOCKED: Sensitive filename pattern '$pattern':${NC}"
            echo "$matches" | sed 's/^/  /'
            errors=$((errors + 1))
        fi
    done
fi

# --- 2. Secrets in diffs ---
secret_patterns=(
    'password\s*='
    'api_key\s*='
    'secret\s*='
    'token\s*='
    'BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY'
    'Bearer [A-Za-z0-9_\-\.]+'
    'AKIA[0-9A-Z]{16}'
)

diff_output=$(git diff --cached --diff-filter=ACMR -U0 2>/dev/null)

if [[ -n "$diff_output" ]]; then
    for pattern in "${secret_patterns[@]}"; do
        matches=$(echo "$diff_output" | grep -E '^\+' | grep -v '^\+\+\+' | grep -iE "$pattern" || true)
        if [[ -n "$matches" ]]; then
            echo -e "${RED}BLOCKED: Potential secret matching '$pattern':${NC}"
            echo "$matches" | head -5 | sed 's/^/  /'
            errors=$((errors + 1))
        fi
    done
fi

# --- 3. Personal email addresses (warn, don't block) ---
email_domains=(
    '@mailbox\.org'
    '@humanspark\.ai'
    '@gmail\.com'
    '@yahoo\.com'
    '@hotmail\.com'
    '@outlook\.com'
)

if [[ -n "$staged_files" ]]; then
    non_test_files=$(echo "$staged_files" | grep -v -E '(^tests/|/tests/|test_|_test\.|fixtures/)' || true)
    if [[ -n "$non_test_files" ]]; then
        for domain in "${email_domains[@]}"; do
            matches=$(echo "$diff_output" | grep -E '^\+' | grep -v '^\+\+\+' | grep -iE "$domain" || true)
            if [[ -n "$matches" ]]; then
                echo -e "${YELLOW}WARNING: Personal email address (${domain}) in staged changes:${NC}"
                echo "$matches" | head -3 | sed 's/^/  /'
                warnings=$((warnings + 1))
            fi
        done
    fi
fi

# --- 4. Stub justification (Rule 4.9): Why + Trigger required ---
#
# Any newly-added spec in docs/plans/*.md, or any newly-added TODO/STUB code
# comment, must carry a "Why" and "Trigger" line. Blocks stubs that would
# decay into unactionable backlog. Matches Rule 4.9 in the engineering
# standards reference doc.

# 4a: Spec files in docs/plans/ must contain Why + Trigger sections.
new_spec_files=$(git diff --cached --name-only --diff-filter=A 2>/dev/null | grep -E '^docs/plans/.+\.md$' | grep -v -E '(SPEC-TEMPLATE|\.gitkeep)' || true)

if [[ -n "$new_spec_files" ]]; then
    while IFS= read -r spec_file; do
        [[ -z "$spec_file" ]] && continue
        content=$(git show ":$spec_file" 2>/dev/null || true)
        if ! echo "$content" | grep -qiE '(^|\*\*)Why[: ]'; then
            echo -e "${RED}BLOCKED: Spec missing 'Why:' line (Rule 4.9): $spec_file${NC}"
            errors=$((errors + 1))
        fi
        if ! echo "$content" | grep -qiE '(^|\*\*)Trigger[: ]'; then
            echo -e "${RED}BLOCKED: Spec missing 'Trigger:' line (Rule 4.9): $spec_file${NC}"
            errors=$((errors + 1))
        fi
    done <<< "$new_spec_files"
fi

# 4b: New TODO/STUB comments in added lines must have Why + Trigger on nearby lines.
# Scan added lines for TODO:/STUB:/FIXME: markers; for each, check the next 4
# added lines in the same hunk for Why and Trigger. Uses a Python helper for
# the windowed check (bash line-proximity in unified diff is fragile).
if [[ -n "$diff_output" ]]; then
    stub_report=$(python3 - <<'PY' 2>/dev/null || true
import re, subprocess, sys

diff = subprocess.run(
    ["git", "diff", "--cached", "--diff-filter=ACMR", "-U0"],
    capture_output=True, text=True, check=False,
).stdout

markers = re.compile(r'(TODO|STUB|FIXME)\s*:', re.I)
skip_paths = re.compile(r'(^|/)(tests?|fixtures?)/|/node_modules/|reference/humanspark-engineering-standards-v1\.md$|user-level/hooks/pre-commit$|^CLAUDE\.md$|user-level/CLAUDE\.md$|project-template/CLAUDE\.md$|docs/SPEC-TEMPLATE\.md$|docs/MODULE-README-TEMPLATE\.md$')

current_file = None
added = []
violations = []

def flush(added_lines):
    for i, line in enumerate(added_lines):
        if markers.search(line):
            window = "\n".join(added_lines[i:i+5])
            if not re.search(r'Why\s*:', window, re.I) or not re.search(r'Trigger\s*:', window, re.I):
                violations.append((current_file, line.strip()[:120]))

for raw in diff.splitlines():
    if raw.startswith("+++ b/"):
        flush(added)
        added = []
        current_file = raw[6:]
        continue
    if raw.startswith("diff --git") or raw.startswith("@@"):
        flush(added)
        added = []
        continue
    if raw.startswith("+") and not raw.startswith("+++"):
        added.append(raw[1:])

flush(added)

for path, snippet in violations:
    if path and skip_paths.search(path):
        continue
    print(f"{path}\t{snippet}")
PY
)
    if [[ -n "$stub_report" ]]; then
        echo -e "${RED}BLOCKED: TODO/STUB/FIXME without 'Why:' + 'Trigger:' nearby (Rule 4.9):${NC}"
        echo "$stub_report" | head -10 | sed 's/^/  /'
        errors=$((errors + 1))
    fi
fi

# --- Summary ---
if [[ $errors -gt 0 ]]; then
    echo ""
    echo -e "${RED}Commit blocked: $errors issue(s) found.${NC}"
    echo "Override with: git commit --no-verify"
    exit 1
fi

if [[ $warnings -gt 0 ]]; then
    echo -e "${YELLOW}Commit proceeding with $warnings warning(s).${NC}"
fi

exit 0
