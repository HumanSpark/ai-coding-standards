{
  "permissions": {
    "allow": [
      "Read",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(docs/**)",
      "Edit(CLAUDE.md)",
      "Edit(README.md)",
      "Bash(python -m py_compile *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m py_compile *)",
      "Bash(python3 -m pytest *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(cat *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.env.shared)",
      "Read(**/secrets/**)",
      "Read(**/*credentials*)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$CLAUDE_TOOL_INPUT\" | grep -oP '\"file_path\":\\s*\"\\K[^\"]+' 2>/dev/null || echo ''); if [ -n \"$FILE\" ] && echo \"$FILE\" | grep -q '\\.py$'; then python3 -m py_compile \"$FILE\" 2>&1 && echo '{\"feedback\": \"syntax ok\"}' || echo \"{\\\"feedback\\\": \\\"syntax error in $FILE\\\"}\"; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
